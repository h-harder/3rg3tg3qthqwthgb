{
  "name": "homechat-handoff",
  "version": "2.0.0",
  "description": "Self-hosted home chat with logins, moderator controls, terminal menu, cross-platform services, and Ubuntu/macOS active-passive handoff.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "menu": "node bin/chatctl.js menu",
    "chatctl": "node bin/chatctl.js",
    "setup": "npm install --omit=dev"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "helmet": "^8.0.0",
    "socket.io": "^4.8.1"
  }
}
